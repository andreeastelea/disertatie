# Backend environment overrides for local development
# Copy this file to backend/.env and adjust values as needed.
DB_TYPE=sql
# Either use DATABASE_URL or the fields below.
DATABASE_URL=
DB_USER=perfuser
DB_PASSWORD=perfpass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=perfdb
# Ensure this DB user has permission to create tables in the chosen database/schema.

# MongoDB configuration (use when DB_TYPE=nosql)
# MONGO_URI=mongodb://localhost:27017/
# MONGO_DB_NAME=perfdb

BACKEND_PORT=5000
SECRET_KEY=dev-secret-key-change-in-prod
